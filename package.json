    "postinstall": "node scripts/patch-autosizing-stack.js && patch-package",
    "prebuild:ios": "npm run patch-autosizing-stack",
    "build:ios": "npm run prebuild:ios && eas build --platform ios",
    "ios:rebuild": "npm run patch-autosizing-stack && cd ios && pod install && cd .. && npx expo run:ios"
  },
